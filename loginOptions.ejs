<div id="loginOptionsContainer" style="display: none;">
    <div id="loginOptionsContent">
        <div class="loginOptionsMainContent">
            <h2><%- lang('loginOptions.loginOptionsTitle') %></h2>
            <div class="loginOptionActions">
                <div class="loginOptionButtonContainer">
                    <button id="loginOptionMicrosoft" class="loginOptionButton">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 23 23">
                            <path fill="#f35325" d="M1 1h10v10H1z" />
                            <path fill="#81bc06" d="M12 1h10v10H12z" />
                            <path fill="#05a6f0" d="M1 12h10v10H1z" />
                            <path fill="#ffba08" d="M12 12h10v10H12z" />
                        </svg>
                        <span><%- lang('loginOptions.loginWithMicrosoft') %></span>
                    </button>
                </div>
                <div class="loginOptionButtonContainer">
                    <button id="loginOptionMojang" class="loginOptionButton">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 9.677 9.667">
                            <path d="M-26.332-12.098h2.715c-1.357.18-2.574 1.23-2.715 2.633z" fill="#fff" />
                            <path d="M2.598.022h7.07L9.665 7c-.003 1.334-1.113 2.46-2.402 2.654H0V2.542C.134 1.2 1.3.195 2.598.022z" fill="#db2331" />
                            <path d="M1.54 2.844c.314-.76 1.31-.46 1.954-.528.785-.083 1.503.272 2.1.758l.164-.9c.327.345.587.756.964 1.052.28.254.655-.342.86-.013.42.864.408 1.86.54 2.795l-.788-.373C6.9 4.17 5.126 3.052 3.656 3.685c-1.294.592-1.156 2.65.06 3.255 1.354.703 2.953.51 4.405.292-.07.42-.34.87-.834.816l-4.95.002c-.5.055-.886-.413-.838-.89l.04-4.315z" fill="#fff" />
                        </svg>
                        <span><%- lang('loginOptions.loginWithMojang') %></span>
                    </button>
                </div>
                <div class="loginOptionButtonContainer">
                    <button id="loginOptionOffline" class="loginOptionButton">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                        <span>Entrar Offline (Pirata)</span>
                    </button>
                </div>
            </div>
            <div id="loginOptionCancelContainer" style="display: none;">
                <button id="loginOptionCancelButton"><%- lang('loginOptions.cancelButton') %></button>
            </div>
        </div>
    </div>
    <!-- Offline Login Modal -->
    <div id="offlineLoginModal" style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10,10,18,0.85); z-index: 600; display: none; align-items: center; justify-content: center;">
        <div style="background: rgba(10,10,18,0.95); border: 1px solid rgba(245,166,35,0.3); border-radius: 8px; padding: 30px 40px; text-align: center; max-width: 350px;">
            <h3 style="color: #f5a623; margin: 0 0 5px; font-size: 18px; letter-spacing: 1px;">Entrar Offline</h3>
            <p style="color: rgba(255,255,255,0.5); font-size: 11px; margin: 0 0 20px;">Digite o nome que será exibido no jogo.</p>
            <input type="text" id="offlineUsername" placeholder="Seu nome no jogo..." maxlength="16" style="
                width: 100%;
                padding: 10px 14px;
                border-radius: 6px;
                border: 1px solid rgba(245,166,35,0.3);
                background: rgba(0,0,0,0.5);
                color: #f5a623;
                font-family: 'Avenir Book';
                font-size: 14px;
                outline: none;
                box-sizing: border-box;
                text-align: center;
                letter-spacing: 1px;
            "/>
            <div style="display: flex; gap: 10px; margin-top: 15px;">
                <button id="offlineLoginCancel" style="
                    flex: 1;
                    padding: 8px;
                    background: none;
                    border: 1px solid rgba(255,255,255,0.2);
                    color: rgba(255,255,255,0.5);
                    border-radius: 4px;
                    font-family: 'Avenir Book';
                    font-size: 12px;
                    cursor: pointer;
                    transition: 0.25s ease;
                ">Cancelar</button>
                <button id="offlineLoginConfirm" style="
                    flex: 2;
                    padding: 8px;
                    background: rgba(245,166,35,0.15);
                    border: 1px solid rgba(245,166,35,0.4);
                    color: #f5a623;
                    border-radius: 4px;
                    font-family: 'Avenir Medium';
                    font-size: 12px;
                    cursor: pointer;
                    transition: 0.25s ease;
                    letter-spacing: 1px;
                ">ENTRAR ✦</button>
            </div>
        </div>
    </div>
    <script src="./assets/js/scripts/loginOptions.js"></script>
    <script>
    // Offline login logic
    document.getElementById('loginOptionOffline').addEventListener('click', function() {
        const modal = document.getElementById('offlineLoginModal')
        modal.style.display = 'flex'
        document.getElementById('offlineUsername').focus()
    })
    document.getElementById('offlineLoginCancel').addEventListener('click', function() {
        document.getElementById('offlineLoginModal').style.display = 'none'
    })
    document.getElementById('offlineLoginConfirm').addEventListener('click', function() {
        const name = document.getElementById('offlineUsername').value.trim()
        if(name.length >= 3 && name.length <= 16) {
            // Generate offline UUID
            const offlineUUID = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
                const r = Math.random() * 16 | 0
                return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16)
            })
            const ConfigManager = require('./assets/js/configmanager')
            ConfigManager.addMojangAuthAccount(offlineUUID, 'offline', name, name)
            ConfigManager.save()
            // Switch to landing
            document.getElementById('offlineLoginModal').style.display = 'none'
            switchView(getCurrentView(), VIEWS.landing)
        }
    })
    document.getElementById('offlineUsername').addEventListener('keypress', function(e) {
        if(e.key === 'Enter') document.getElementById('offlineLoginConfirm').click()
    })
    </script>
</div>
